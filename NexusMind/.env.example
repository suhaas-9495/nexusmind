# ─────────────────────────────────────────────
# NexusMind — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Ollama (running locally)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
EMBED_MODEL=nomic-embed-text
TEMPERATURE=0.1

# Qdrant (running locally via Docker)
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=nexusmind_docs
VECTOR_SIZE=768

# Retrieval
TOP_K=5

# Chunking
CHUNK_WORDS=400
CHUNK_OVERLAP=0.15

# Agent limits
AGENT_MAX_STEPS=6
AGENT_MAX_RETRIES=2
AGENT_TIMEOUT_SEC=120
